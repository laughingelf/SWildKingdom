---
const groups = [
  { title: "Mammals", desc: "Fur, warm-blooded, and all kinds of wild behaviors", key: "Mammals" },
  { title: "Birds", desc: "Feathers, flight, and amazing migration journeys", key: "Birds" },
  { title: "Reptiles", desc: "Scales, sun-basking, and ancient survival skills", key: "Reptiles" },
  { title: "Amphibians", desc: "Frogs, salamanders, and life between land and water", key: "Amphibians" },
  { title: "Fish", desc: "Freshwater and ocean life beneath the surface", key: "Fish" },
  { title: "Insects", desc: "Ants, bees, beetles, and tiny creatures doing big things", key: "Insects" },
  { title: "Arachnids", desc: "Spiders and scorpions with serious skills", key: "Arachnids" },
  { title: "Marine Life", desc: "Creatures from reefs, coasts, and deep water", key: "Marine Life" },
];

const toQuery = (key: string) => encodeURIComponent(key);
---

<section class="section" aria-label="Explore wildlife">
  <header class="head">
    <div>
      <p class="kicker">Explore</p>
      <h2 class="title">Browse wildlife groups</h2>
      <p class="sub">
        Pick a group to explore facts. More animals get added over time.
      </p>
    </div>
    <a class="all" href="/facts">All facts →</a>
  </header>

  <div class="grid">
    {groups.map((g) => (
      <a class="card" href={`/facts?group=${toQuery(g.key)}`}>
        <div class="card-top">
          <span class="pill">{g.title}</span>
        </div>
        <p class="desc">{g.desc}</p>
        <span class="go">Explore →</span>
      </a>
    ))}
  </div>
</section>

<style>
  .section { padding: 1.25rem 0 0.25rem; }

  .head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .kicker {
    margin: 0 0 0.35rem;
    font-weight: 900;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--text-muted) 70%, var(--primary) 30%);
  }

  .title { margin: 0; font-size: 1.6rem; letter-spacing: -0.02em; }

  .sub {
    margin: 0.5rem 0 0;
    color: var(--text-muted);
    line-height: 1.6;
    max-width: 70ch;
  }

  .all {
    text-decoration: none;
    font-weight: 900;
    color: var(--primary-dark);
    white-space: nowrap;
  }
  .all:hover { text-decoration: underline; }

  .grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card {
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--bg-card);
    padding: 1.15rem;
    box-shadow: 0 18px 60px rgba(0,0,0,.05);
    display: grid;
    gap: 0.65rem;
    transition: transform 140ms ease, box-shadow 140ms ease;
    color: var(--text-main);
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 70px rgba(0,0,0,.08);
  }

  .pill {
    display: inline-flex;
    width: fit-content;
    font-size: 0.75rem;
    font-weight: 900;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--primary) 30%, var(--border) 70%);
    background: rgba(255,255,255,.85);
    color: var(--primary-dark);
  }

  .desc {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .go {
    width: fit-content;
    font-weight: 900;
    color: var(--primary-dark);
  }

  @media (max-width: 980px) {
    .head { align-items: flex-start; flex-direction: column; }
    .grid { grid-template-columns: 1fr; }
  }
</style>