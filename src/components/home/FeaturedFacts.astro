---
import { supabaseServer } from "../../lib/supabaseServer";

type Fact = {
  id: string;
  title: string;
  fact: string;
  category: string;
  created_at: string;
};

const { data, error } = await supabaseServer
  .from("facts")
  .select("id,title,fact,category,created_at")
  .eq("published", true)
  .order("created_at", { ascending: false })
  .limit(3);

const facts: Fact[] = (!error && data) ? (data as Fact[]) : [];

const trim = (s: string, n = 140) => (s.length > n ? s.slice(0, n).trim() + "…" : s);
---

<section class="section" aria-label="Featured facts">
  <header class="head">
    <div>
      <p class="kicker">Featured</p>
      <h2 class="title">Latest facts</h2>
    </div>
    <a class="all" href="/facts">View all →</a>
  </header>

  {facts.length === 0 ? (
    <div class="empty">
      <p class="empty-title">No facts published yet</p>
      <p class="empty-text">Once Sawyer publishes facts, the newest ones will show up here.</p>
    </div>
  ) : (
    <div class="grid">
      {facts.map((f) => (
        <article class="card">
          <div class="card-top">
            <span class="badge">{f.category}</span>
          </div>
          <h3 class="card-title">{f.title}</h3>
          <p class="card-body">{trim(f.fact)}</p>
          <a class="card-link" href="/facts">Read more →</a>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  .section {
    margin-top: 1.25rem;
    padding: 1.25rem 0 0.25rem;
  }

  .head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.9rem;
  }

  .kicker {
    margin: 0 0 0.35rem;
    font-weight: 900;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--text-muted) 70%, var(--primary) 30%);
  }

  .title {
    margin: 0;
    font-size: 1.6rem;
    letter-spacing: -0.02em;
  }

  .all {
    text-decoration: none;
    font-weight: 900;
    color: var(--primary-dark);
  }

  .all:hover { text-decoration: underline; }

  .grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--bg-card);
    padding: 1.15rem;
    box-shadow: 0 18px 60px rgba(0,0,0,.05);
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .card-top {
    display: flex;
    justify-content: flex-start;
  }

  .badge {
    font-size: 0.75rem;
    font-weight: 900;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    border: 1px solid color-mix(in oklab, var(--primary) 30%, var(--border) 70%);
    background: rgba(255,255,255,.85);
    color: var(--primary-dark);
    white-space: nowrap;
  }

  .card-title {
    margin: 0;
    font-size: 1.05rem;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }

  .card-body {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .card-link {
    width: fit-content;
    text-decoration: none;
    font-weight: 900;
    color: var(--primary-dark);
    margin-top: 0.25rem;
  }

  .card-link:hover { text-decoration: underline; }

  .empty {
    border: 1px solid var(--border);
    border-radius: 22px;
    background: color-mix(in oklab, var(--accent-soft) 22%, white 78%);
    padding: 1.15rem;
  }

  .empty-title {
    margin: 0 0 0.35rem;
    font-weight: 900;
  }

  .empty-text {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 980px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>