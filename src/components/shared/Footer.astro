---
const year = new Date().getFullYear();
const siteName = "Sawyer’s Animal Kingdom";
---

<footer class="footer-wrap">
  <div class="footer">
    <div class="brand">
      <div class="mark" aria-hidden="true"></div>
      <div class="brand-text">
        <p class="name">{siteName}</p>
        <p class="tagline">Facts, discoveries, and experiments by Sawyer.</p>
      </div>
    </div>

    <div class="links">
      <a href="/facts">Facts</a>
      <a href="/">Home</a>
      <!-- keep admin subtle -->
      <!-- <a href="/boog/sawyer" aria-label="Admin login">Login</a> -->
    </div>

    <div class="meta">
  <p>© {year} {siteName}</p>

  <div class="meta-links">
    <span class="subtle">
      Built with Astro • Powered by Supabase
    </span>
    <a class="login" href="/boog/sawyer">login</a>
  </div>
</div>

  </div>
</footer>

<style>
  .footer-wrap {
    border-top: 1px solid var(--border);
    background: color-mix(in oklab, var(--bg-main) 70%, white 30%);
  }

  .footer {
    width: min(100% - 2rem, 1100px);
    margin-inline: auto;
    padding: 2rem 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1.2fr 0.8fr 1fr;
    align-items: start;
  }

  .brand {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .mark {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    background:
      radial-gradient(circle at 30% 30%, var(--accent) 0 28%, transparent 30%),
      radial-gradient(circle at 65% 55%, var(--primary) 0 32%, transparent 34%),
      radial-gradient(circle at 45% 75%, var(--text-main) 0 10%, transparent 12%);
    border: 1px solid var(--border);
    box-shadow: 0 10px 30px rgba(0,0,0,.06);
  }

  .name {
    margin: 0;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .tagline {
    margin: 0.35rem 0 0;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .links {
    display: grid;
    gap: 0.5rem;
  }

  .links a {
    color: var(--text-main);
    text-decoration: none;
    font-weight: 650;
    width: fit-content;
    border-bottom: 1px solid transparent;
  }

  .links a:hover {
    border-bottom-color: var(--accent);
  }

 .meta {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.meta-links {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  flex-wrap: wrap;
}

.subtle {
  color: var(--text-muted);
  font-size: 0.85rem;
}

.login {
  font-size: 0.8rem;
  color: var(--text-muted);
  text-decoration: none;
  opacity: 0.6;
}

.login:hover {
  opacity: 1;
  text-decoration: underline;
}


  .subtle {
    margin-top: 0.35rem;
    color: var(--text-muted);
  }

  @media (max-width: 820px) {
    .footer {
      grid-template-columns: 1fr;
    }
  }
</style>
